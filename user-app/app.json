{
  "expo": {
    "name": "Eco-Donation",
    "slug": "user-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "userapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#004d40",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.userapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-maps",
        {
          "useGoogleMaps": false
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izinkan Eco-Donation mengakses lokasi Anda untuk menentukan titik penjemputan sampah."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#004d40"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan Eco-Donation mengakses kamera untuk scan QR Code kurir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}